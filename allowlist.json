{
  "_comment": "公開可能な allowlist（汎用例のみ、具体的な個人名/メール/パスは含まない）。環境固有の許可は allowlist.local.json（.gitignore）に書く。両ファイルはマージされる。下記は自身の test フィクスチャ（RFC予約サンプル）の許可。",
  "allow": [
    {"match": "203.0.113.", "reason": "RFC5737 documentation/test IP fixture", "pathGlob": "**/test/**"},
    {"match": "198.51.100.", "reason": "RFC5737 TEST-NET-2 IP fixture", "pathGlob": "**/test/**"},
    {"match": "2001:db8:", "reason": "RFC3849 documentation IPv6 fixture", "pathGlob": "**/test/**"},
    {"match": "@example.", "reason": "RFC2606 example domain (test/docs fixture)", "pathGlob": "**/test/**"},
    {"match": "@example.", "reason": "example author email in plugin.json fixture", "pathGlob": "**/plugin.json"},
    {"match": "@realcorp.io", "reason": "test fixture domain", "pathGlob": "**/test/**"},
    {"match": "C:/Users/", "reason": "home-path test fixture (alice/bob/<other>)", "pathGlob": "**/test/**"}
  ]
}
